      ],
      "id": "interaction-model",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: interaction-plot\n",
        "#| fig-cap: 'Interaction: effect of weight differs by transmission type'\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "colors = {0: \"#4C72B0\", 1: \"#DD4444\"}\n",
        "labels = {0: \"Automatic\", 1: \"Manual\"}\n",
        "\n",
        "for am_val, grp in mtcars.groupby(\"am\"):\n",
        "    ax.scatter(grp[\"wt\"], grp[\"mpg\"],\n",
        "               color=colors[am_val], label=labels[am_val],\n",
        "               alpha=0.8, edgecolors=\"white\", s=70)\n",
        "    x_r = np.linspace(grp[\"wt\"].min(), grp[\"wt\"].max(), 100)\n",
        "    b0  = model_int.params[\"Intercept\"]\n",
        "    b1  = model_int.params[\"wt\"]\n",
        "    b2  = model_int.params[\"am\"]\n",
        "    b3  = model_int.params[\"wt:am\"]\n",
        "    y_r = b0 + b1*x_r + b2*am_val + b3*x_r*am_val\n",
        "    ax.plot(x_r, y_r, color=colors[am_val], linewidth=2)\n",
        "\n",
        "ax.set_xlabel(\"Weight (1000 lbs)\")\n",
        "ax.set_ylabel(\"Miles per Gallon\")\n",
        "ax.set_title(\"mpg ~ wt × Transmission Type\")\n",
        "ax.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "interaction-plot",
      "execution_count": null,
      "outputs": []
