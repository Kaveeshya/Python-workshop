        "---\n",
        "\n",
        "# Model Diagnostics {#sec-diagnostics}\n",
        "\n",
        "Reliable OLS inference requires checking four key assumptions.\n",
        "\n",
        "## Residuals vs Fitted"
      ],
      "id": "2451095c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: resid-fitted\n",
        "#| fig-cap: Residuals vs Fitted — checking linearity & homoscedasticity\n",
        "\n",
        "fitted   = model_mlr.fittedvalues\n",
        "residuals = model_mlr.resid\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "ax.scatter(fitted, residuals, color=\"#4C72B0\", alpha=0.7, edgecolors=\"white\", s=60)\n",
        "ax.axhline(0, linestyle=\"--\", color=\"gray\")\n",
        "ax.set_xlabel(\"Fitted Values\")\n",
        "ax.set_ylabel(\"Residuals\")\n",
        "ax.set_title(\"Residuals vs Fitted\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "resid-fitted",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Q-Q Plot (Normality of Residuals)"
      ],
      "id": "1c41043a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: qq-plot\n",
        "#| fig-cap: Q-Q Plot — residuals should follow the diagonal for normality\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "sm.qqplot(residuals, line=\"s\", ax=ax, alpha=0.6)\n",
        "ax.set_title(\"Normal Q-Q Plot of Residuals\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "qq-plot",
